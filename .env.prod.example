# ============================================================
# X-box 生产环境变量模板（提交仓库，占位值上线前用强随机替换）
# 使用: cp .env.prod.example .env.prod && 填入真实值（.env.prod 勿提交，已被 .gitignore）
# 变量清单来自 .env.dev.example + docker-compose.prod.yml 实际引用
# 务必先读《X-box部署方案.md》风险点 R1 / R2 再填库名与数据库密码
# ============================================================

# ===== .env.prod（生产，严禁提交仓库）=====
# 下方内容完整复现《X-box部署方案.md》第 6 节模板，并新增班级网站 CLASS_DB_* 段

# === MySQL：ROOT 仅用于容器初始化，勿复用为业务口令 ===
MYSQL_ROOT_PASSWORD=<openssl rand -base64 18 生成>

# ⚠️ R1：db/mysql_init/init.sql 实际创建的是 prj_dev，必须与后端 datasource 库名一致
#      → 设为 prj_dev（不改源码）；若要 prj_prod 则需同步改 init.sql
MYSQL_DATABASE=prj_dev

# === 后端业务数据库账号（R2：密码必须与 init.sql 中 prj_user 的密码一致）===
PRJ_DB_USER=prj_user
PRJ_DB_PWD=Prj@Dev789
SPRING_DATASOURCE_USERNAME=prj_user
SPRING_DATASOURCE_PASSWORD=Prj@Dev789

# === Redis ===
REDIS_PASSWORD=<openssl rand -base64 24 生成>

# === JWT（prod profile 强制 ≥256-bit 强密钥，弱/缺失即启动失败）===
JWT_SECRET=<openssl rand -base64 32 生成>

# === Druid 监控台 ===
DRUID_USERNAME=druid_admin
DRUID_PASSWORD=<openssl rand -base64 24 生成>

# === Swagger（生产关闭）===
SWAGGER_ENABLED=false

# === AI 服务令牌（后端调用 Ollama 时携带）===
AI_API_TOKEN=<openssl rand -base64 24 生成>

# ============================================================
# 新增：班级网站 Niu_Txl（prj-php）专用
# 902 的 conn.php 读取以下变量连接 dev-mysql；详见《X-box-Niu_Txl整合设计.md》
# ============================================================
CLASS_DB_HOST=dev-mysql
CLASS_DB_USER=class_user
# 强随机占位：上线前执行 `openssl rand -base64 24` 生成并填入，勿提交明文
CLASS_DB_PWD=
# ⚠️ CLASS_DB_NAME 绝对不要设！两个站点共享同一容器进程：
#   902/message/conn.php → 回退 'msg'
#   902/work/conn.php    → 回退 'work'
# 若设此变量会导致一个站点连错库（Table 'xxx' doesn't exist）
