# ============================================================
# X-box 生产环境变量模板（base 文件，对应真实 .env.prod）
# 使用: cp .env.prod.example .env.prod && 填入实际值（.env.prod 已被 .gitignore 忽略，切勿提交）
#
# [C3/C4] 安全治理：生产环境变量已拆分为「基础文件 .env.prod」+「后端文件 .env.prod.backend」两套。
#  - 本文件经 `docker compose ... --env-file .env.prod` 插值，供基础服务（mysql/redis）与
#    prj-php 业务库连接（CLASS_DB_*）使用；
#  - 后端专用密钥（SPRING_DATASOURCE_*/JWT_SECRET/DRUID_*/SWAGGER_ENABLED/AI_API_TOKEN）
#    已拆至 .env.prod.backend（详见 .env.prod.backend.example），本文件绝不含有后端专用密钥。
# 所有敏感值均为占位符（ChangeMe_*），上线前必须替换为强随机值，切勿将明文口令提交仓库。
# ============================================================

# === MySQL：ROOT 仅用于容器初始化，不作为业务口令复用 ===
MYSQL_ROOT_PASSWORD=ChangeMe_Root

# 【R1】db/mysql_init/init.sql 实际创建的是 prj_dev，必须与后端 datasource 库名一致！
#       此处必须设为 prj_dev（不改源文件）；若要用 prj_prod 则需同步改 init.sql。
MYSQL_DATABASE=prj_dev

# 【R2】凭证契约：PRJ_DB_PWD 与 .env.prod.backend 的 SPRING_DATASOURCE_PASSWORD 必须相同
#      （两者共同决定 dev-mysql 中 prj_user 的口令）。上线前替换为强随机值。
PRJ_DB_USER=prj_user
PRJ_DB_PWD=ChangeMe_Prj

# === Redis ===
REDIS_PASSWORD=ChangeMe_Redis

# === 班级网站（Niu_Txl / prj-php）专用 ===
# 902 的 conn.php 读取以下变量连接 mysql 服务；详见 X-box-Niu_Txl整合设计.md
CLASS_DB_HOST=mysql
CLASS_DB_USER=class_user
# 强随机占位：仅用 [A-Za-z0-9_@.-] 的口令（禁用 $ # ; 等字符，见 .env.prod 注释），勿提交明文
CLASS_DB_PWD=ChangeMe_ClassDb
