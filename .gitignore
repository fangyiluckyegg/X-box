# ====================== 环境变量（敏感，禁止提交） ======================
# [P0-FIX] 通配符屏蔽所有env文件，防止敏感凭据泄露
.env*
*.env
# 仅允许无密码模板文件提交仓库
!.env.dev.example
!.env.prod.example
!.env.backend.example
!.env.prod.backend.example

# ====================== 运行日志 ======================
logs/**
*.log

# ====================== Nginx SSL证书/密钥文件（私钥高危） ======================
gateway/nginx/ssl/*.key
gateway/nginx/ssl/*.crt
gateway/nginx/ssl/*.pem
# [P0-FIX] 全局密钥文件屏蔽，防止任意位置的密钥泄露
*.pem
*.key

# ====================== MySQL/Redis 持久化数据 ======================
# 完整屏蔽数据目录，无需单独屏蔽库内文件
db/mysql_data/
db/redis_data/

# [P0-FIX] init.sql 是数据库初始化脚本，必须在版本控制中
# 其中开发默认密码与 application.yml 的 SPRING_DATASOURCE_PASSWORD 默认值一致
# 生产部署后必须执行 ALTER USER 修改密码

# ====================== AI Llama 模型与缓存 ======================
ai_llama/models/
ai_llama/cache/

# SSH私钥（精准匹配 + 通配符双重防护防泄露）
ai_llama/id_ed25519
ai_llama/id_ed25519.pub
# [P0-FIX] 通配符屏蔽所有位置的SSH私钥
**/id_*

# ====================== 前端Vue产物/依赖 ======================
# [P0-FIX] 路径修正：实际目录名为 prj-frontend（连字符）
web/prj-frontend/dist/
web/prj-frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================== 后端Maven编译产物 ======================
backend/prj-backend-c/dependency-reduced-pom.xml
backend/prj-backend-c/target/
# Maven本地缓存
.m2/

# ====================== Docker & 容器临时文件 ======================
.docker/
**/tmp/
**/temp/

# DevContainer VSCode远程容器本地缓存
.devcontainer/**.cache
.devcontainer/devcontainer-lock.json
.devcontainer/.vscode/
.devcontainer/temp-*

# ====================== Python/AI脚本缓存 ======================
__pycache__/
*.pyc
*.pyo
*.pyd

# ====================== IDE & 系统隐藏文件 ======================
.idea/
.vscode/
.DS_Store
Thumbs.db

# ====================== Niu_Txl 个人照片/视频/归档（禁止入库） ======================
# [核查] 2026-07-15 扫描：1518 文件 / 1825.93 MB，其中 ~99.9% 为二进制个人数据
Niu_Txl/_quarantine/
# 仅排除照片/视频/压缩包/Office/隔离目录；.php/.html/.js/.css/.sql 等文本源码保留可入库
Niu_Txl/607/永远的607/

# [2026-07-22 瘦身] 902 子目录递归屏蔽个人二进制(照片/视频/字体/压缩包/Office)，文本源码(.php/.html/.js/.css/.sql)保留
# 修复点：原先只屏蔽了 607 与 902/work/admin/upload，导致 902/message/images 照片与
# 902/message/tinymce 的 gif/ttf/woff 等二进制被误入库（占仓库 ~12.5MB）
Niu_Txl/902/message/images/
Niu_Txl/902/message/tinymce/
Niu_Txl/902/work/admin/upload/