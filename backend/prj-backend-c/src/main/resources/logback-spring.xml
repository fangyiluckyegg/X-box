<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 关键：定义容器内日志存储目录，和docker挂载路径 /app/logs 对应 -->
    <property name="log.base.path" value="/app/logs"/>
    <!-- 日志输出格式，线程号、日志级别、输出时间、日志信息 -->
	<property name="log.pattern" value="[%thread]%d{HH:mm:ss.SSS} %-5level %logger{25} - %msg%n" />

	<!-- 控制台输出 指定向控制台输出，指定输出方式和格式-->
	<appender name="console" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>${log.pattern}</pattern>
		</encoder>
	</appender>
	
	<!-- 系统日志输出，指定向文件输出日志，明确方法与格式 -->
	<appender name="file_info" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 每天输出一个文件，同时定义日志文件名格式 -->
			<!-- <fileNamePattern>info.%d{yyyy-MM-dd}.log</fileNamePattern> -->
            <!-- 在 fileNamePattern 拼接 ${log.base.path}/，让日志写入 /app/logs -->
            <fileNamePattern>${log.base.path}/info.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 可选：限制日志保留天数，防止磁盘占满 -->
            <maxHistory>30</maxHistory>
		</rollingPolicy>
		<encoder>
			<pattern>${log.pattern}</pattern>
		</encoder>
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
            <!-- 过滤的级别，输出含INFO和高于INFO级别的日志，如WARN和ERROR级别日志-->
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>NEUTRAL</onMismatch>
        </filter>
	</appender>
	
	<appender name="file_error" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 每天输出一个文件，同时定义日志文件名格式 -->
            <!-- <fileNamePattern>error.%d{yyyy-MM-dd}.log</fileNamePattern> -->
            <fileNamePattern>${log.base.path}/error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 可选：限制日志保留天数，防止磁盘占满 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${log.pattern}</pattern>
        </encoder>
        <!-- 只输出ERROR级别的日志 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!--
    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>localhost:9601</destination>
        <encoder charset="UTF-8" class="net.logstash.logback.encoder.LogstashEncoder" >
            <customFields>{"appname":"HrManager"}</customFields>
        </encoder>
    </appender>
    -->

	<!--系统操作日志（默认：文本格式 console + file_info + file_error）-->
    <root level="info">
        <appender-ref ref="console" />
        <appender-ref ref="file_info" />
        <appender-ref ref="file_error" />
        <!-- <appender-ref ref="LOGSTASH" /> -->
    </root>

    <!-- [P2-FIX] JSON 格式日志，通过 spring profile "json-logs" 激活 -->
    <!-- 生产环境通过 SPRING_PROFILES_ACTIVE=dev,json-logs 激活，输出结构化日志供 ELK 采集 -->
    <!-- 文件日志保持文本格式不变，仅 console 切换为 JSON，最小变更保证兼容性 -->
    <springProfile name="json-logs">
        <appender name="json_console" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"prj-backend"}</customFields>
            </encoder>
        </appender>
        <root level="info">
            <appender-ref ref="json_console" />
            <appender-ref ref="file_info" />
            <appender-ref ref="file_error" />
        </root>
    </springProfile>

</configuration>
