# ============================================================
# PRJ 项目开发环境变量模板（base 文件）
# 使用: cp .env.dev.example .env.dev && 填入实际值（.env.dev 已被 .gitignore 忽略，切勿提交）
#
# [C3/C4] 安全治理：开发环境变量已拆分为「基础文件 .env.dev」+「后端文件 .env.backend」两套。
#  - 本文件仅含 base 服务的密钥（被 docker-compose.base.yml 经 .env.dev 注入，
#    供 mysql/redis 容器初始化与 prj-php 业务库连接使用）；
#  - 后端业务密钥（JWT/DRUID/REDIS/SWAGGER/AI/SPRING_DATASOURCE/SPRING_DATA_REDIS 等）
#    已拆至 .env.backend（详见 .env.backend.example），本文件绝不含有后端专用密钥。
# 所有敏感值均为占位符（ChangeMe_*），本地复制后务必替换为实际强随机值。
# ============================================================

# === MySQL（ROOT 账号，仅供 mysql 容器初始化，勿复用为业务口令）===
MYSQL_ROOT_PASSWORD=ChangeMe_Root

# === Prj 业务数据库账号（base 文件，供 prj-php / mysql 初始化使用）===
PRJ_DB_USER=prj_user
PRJ_DB_PWD=ChangeMe_Prj
SPRING_DATASOURCE_USERNAME=prj_user
SPRING_DATASOURCE_PASSWORD=ChangeMe_Prj

# === AI 向量服务令牌（预留占位：当前 Ollama 默认无鉴权，保留作纵深防御）===
AI_API_TOKEN=ChangeMe_AiToken

# === 班级网站 Niu_Txl（prj-php）专用数据库账号 ===
CLASS_DB_USER=class_user
CLASS_DB_PWD=ChangeMe_ClassDb

# PHP 班级网站 MySQL 服务名（Docker Compose DNS 解析用服务名，非容器名）
CLASS_DB_HOST=mysql
