# ============================================================
# PRJ 项目开发环境变量模板
# [P2-FIX] 文档化所有需要的环境变量，复制为 .env.dev 后修改实际值
# 使用方法: cp .env.dev.example .env.dev && vim .env.dev
# ============================================================

# === MySQL ===
MYSQL_ROOT_PWD=ChangeMe_Root
MYSQL_ROOT_PASSWORD=ChangeMe_Root
PRJ_DB_USER=prj_user
PRJ_DB_PWD=ChangeMe_Prj
SPRING_DATASOURCE_USERNAME=prj_user
SPRING_DATASOURCE_PASSWORD=ChangeMe_Prj

# === Redis ===
REDIS_PASSWORD=ChangeMe_Redis

# === JWT ===
JWT_SECRET=change-me-to-a-strong-256-bit-secret-key

# === Druid ===
DRUID_USERNAME=druid_admin
DRUID_PASSWORD=ChangeMe_Druid

# === Swagger ===
SWAGGER_ENABLED=false

# === AI ===
AI_API_TOKEN=change_me_ai_token
