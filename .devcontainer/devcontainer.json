{
  "name": "后端开发容器",
  "dockerComposeFile": [
    "../docker-compose.base.yml",
    "../docker-compose.business-bibutong.yml"
  ],
  "service": "bibutong-backend",
  "workspaceFolder": "/app",
  "runServices": ["mysql", "redis", "nginx-gateway", "bibutong-backend"],
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack", "humao.rest-client"]
    }
  },
  // 只保留maven，删掉npm那段
  "postCreateCommand": "cd backend/bibutong_server && mvn clean compile -DskipTests"
}