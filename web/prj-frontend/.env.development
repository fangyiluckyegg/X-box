# 页面标题
VUE_APP_TITLE = X工具箱平台

# 开发环境配置
ENV = 'development'

#开发环境
# 改为同源相对路径：经网关访问时，API 走页面同源（http(s)://127.0.0.1/api/）由网关 443/80 的 /api/ 等路由转发后端，
# 避免 HTTPS 页面内调用 http://localhost:8080 触发「主动混合内容」被浏览器拦截。
# 开发者直连 vue dev server(http://localhost:8081) 时，请求落到 dev server，由下方 vue.config.js 的 devServer.proxy 代理到后端容器。
VUE_APP_BASE_API = '/'

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES = true
