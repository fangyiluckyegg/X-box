# ============================================================
# 镜像：前端开发环境（web/prj-frontend/Dockerfile.dev）
# 职责：基于 node:18-alpine 安装依赖并常驻启动 vue-cli 开发服务器（:8081），
#       支持热更新；依赖分层复制以利用构建缓存。
# 说明：暴露 8081 端口，HEALTHCHECK 探测该端口。
# ============================================================

FROM node:18-alpine
WORKDIR /app

# 【关键分层优化】先只复制依赖文件，利用缓存，仅package变更才重装依赖
COPY package.json package-lock.json ./
RUN npm install

COPY . .

# [P2-FIX] 双保险：显式删除可能随 COPY 进入的 logs 目录，
# 避免镜像固化后 bind mount 把空目录同步回宿主 web/prj-frontend/logs/
# （dev 日志统一由 package.json 的 tee 写到 /workspace/logs/prj-frontend/dev.log）
RUN rm -rf /app/logs

EXPOSE 8081
# [P2-FIX] 健康检查：验证 vue-cli 开发服务器是否正常响应（node:18-alpine 自带 wget）
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 CMD wget -qO- http://127.0.0.1:8081/ || exit 1
# 常驻启动 vue-cli 热更新服务
CMD ["npm", "run", "dev"]
