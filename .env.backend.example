# ============================================================
# 后端专用环境变量模板（dev，对应真实 .env.backend）
# 使用: cp .env.backend.example .env.backend && 填入实际值（.env.backend 已被 .gitignore 忽略，切勿提交）
#
# [C4] 最小暴露：本文件绝不含有任何数据库 ROOT 口令（MYSQL_ROOT_PASSWORD）。
# 由 docker-compose.business-prj.dev.yml 通过 env_file 注入后端容器（prj-backend-c）。
# 所有敏感值均为占位符（ChangeMe_*），本地复制后务必替换为实际强随机值；
# 结构值（host/port/库名/username）保留代表值，与开发环境一致。
# ============================================================

# === Spring profile ===
SPRING_PROFILES_ACTIVE=dev

# === 数据源（业务账号 prj_user，非 ROOT）===
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/prj_dev?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=prj_user
SPRING_DATASOURCE_PASSWORD=ChangeMe_Prj

# === Redis ===
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_DATABASE=9
REDIS_PASSWORD=ChangeMe_Redis

# === JWT（开发占位，生产必须替换为 >=256-bit 强密钥）===
JWT_SECRET=ChangeMe_JwtSecret

# === Druid 监控控制台 ===
DRUID_USERNAME=druid_admin
DRUID_PASSWORD=ChangeMe_Druid

# === AI 向量服务 ===
AI_API_TOKEN=ChangeMe_AiToken
AI_SERVICE_URL=http://host.docker.internal:11434
