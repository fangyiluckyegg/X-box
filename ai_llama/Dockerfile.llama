# ============================================================
# 镜像：Ollama 推理服务（ai_llama/Dockerfile.llama）
# 职责：构建自包含 Ollama 镜像，预烘焙业务嵌入模型 bge-m3:latest，
#       供后端 CompareController 通过 /api/embeddings 进行语义向量计算。
# 说明：模型名需与 docker-compose 的 OLLAMA_MODEL、后端 EMBED_MODEL 三者一致。
# ============================================================

# 官方ollama基础镜像，自带ollama二进制
FROM ollama/ollama:0.31.2

WORKDIR /app

# 时区
ENV TZ=Asia/Shanghai
# [P2-8-FIX] ollama 0.1.17 使用 host:port 格式（非 URL 格式）
ENV OLLAMA_HOST=0.0.0.0:11434

# 暴露ollama默认端口11434
EXPOSE 11434

# [C16] 构建期把业务模型 bge-m3:latest 烘焙进镜像，使镜像自包含：
# 启动即无需联网 pull，离线可复现、秒级就绪。
# 注意：本构建步骤需要构建环境可访问 Ollama 模型仓库（联网）；若离线 CI 构建会失败。
# 模型名与 docker-compose 的 OLLAMA_MODEL、后端 CompareController.EMBED_MODEL 三者必须一致。
RUN ollama serve >/tmp/ollama-build.log 2>&1 & \
    SERVE_PID=$! && \
    for i in $(seq 1 30); do \
      if curl -sf http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then break; fi; \
      sleep 1; \
    done && \
    ollama pull bge-m3:latest && \
    kill $SERVE_PID

# [C15] Ollama 启动包装脚本：容器启动时幂等检查业务模型 bge-m3:latest。
# [C16] 模型已在构建期烘焙进镜像（见上方 RUN ollama pull），故运行时一般直接命中、跳过 pull；
# 此处保留为兜底（如改用未烘焙的基础镜像或切换 OLLAMA_MODEL 时自动拉取），避免 /api/embeddings 404。
COPY docker/ollama/docker-entrypoint-llama.sh /app/docker-entrypoint-llama.sh
RUN chmod +x /app/docker-entrypoint-llama.sh
